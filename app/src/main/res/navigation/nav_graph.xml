<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/languageSelectionFragment"
        android:name="com.biasharaai.ui.language.LanguageSelectionFragment"
        android:label="@string/language_selection_title"
        tools:layout="@layout/fragment_language_selection" />

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.biasharaai.ui.home.HomeFragment"
        android:label="@string/nav_home"
        tools:layout="@layout/fragment_home" />

    <fragment
        android:id="@+id/inventoryListFragment"
        android:name="com.biasharaai.ui.inventory.InventoryListFragment"
        android:label="@string/nav_inventory"
        tools:layout="@layout/fragment_inventory_list">

        <action
            android:id="@+id/action_inventoryListFragment_to_addEditProductFragment"
            app:destination="@id/addEditProductFragment" />

        <action
            android:id="@+id/action_inventoryListFragment_to_barcodeScannerFragment"
            app:destination="@id/barcodeScannerFragment" />

    </fragment>

    <!-- AddEditProductFragment (Prompt 5) -->
    <fragment
        android:id="@+id/addEditProductFragment"
        android:name="com.biasharaai.ui.inventory.AddEditProductFragment"
        android:label="@string/inventory_add_edit_title"
        tools:layout="@layout/fragment_add_edit_product">
        <argument
            android:name="product_id"
            app:argType="long"
            android:defaultValue="0L" />
        <argument
            android:name="barcode_value"
            app:argType="string"
            app:nullable="true"
            android:defaultValue="@null" />

        <action
            android:id="@+id/action_addEditProductFragment_to_barcodeScannerFragment"
            app:destination="@id/barcodeScannerFragment" />

        <action
            android:id="@+id/action_addEditProductFragment_to_labelScannerFragment"
            app:destination="@id/labelScannerFragment" />

    </fragment>

    <fragment
        android:id="@+id/labelScannerFragment"
        android:name="com.biasharaai.ui.scanner.LabelScannerFragment"
        android:label="@string/label_scanner_title"
        tools:layout="@layout/fragment_label_scanner" />

    <!-- BarcodeScannerFragment (Prompt 4b) -->
    <fragment
        android:id="@+id/barcodeScannerFragment"
        android:name="com.biasharaai.ui.scanner.BarcodeScannerFragment"
        android:label="@string/inventory_scanner_title"
        tools:layout="@layout/fragment_barcode_scanner">

        <argument
            android:name="scan_mode"
            app:argType="string"
            android:defaultValue="SCAN_FOR_LOOKUP" />

        <action
            android:id="@+id/action_barcodeScannerFragment_to_addEditProductFragment"
            app:destination="@id/addEditProductFragment" />

    </fragment>

    <fragment
        android:id="@+id/chatFragment"
        android:name="com.biasharaai.ui.chat.ChatFragment"
        android:label="@string/nav_chat"
        tools:layout="@layout/fragment_chat" />

    <fragment
        android:id="@+id/insightsFragment"
        android:name="com.biasharaai.ui.insights.CashFlowInsightsFragment"
        android:label="@string/nav_insights"
        tools:layout="@layout/fragment_cash_flow_insights" />

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.biasharaai.ui.settings.SettingsFragment"
        android:label="@string/nav_settings"
        tools:layout="@layout/fragment_settings" />

</navigation>
