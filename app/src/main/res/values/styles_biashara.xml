<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="ShapeAppearance.Biashara.SmallComponent" parent="ShapeAppearance.Material3.Corner.Medium">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>

    <style name="ShapeAppearance.Biashara.MediumComponent" parent="ShapeAppearance.Material3.Corner.Medium">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <style name="ShapeAppearance.Biashara.LargeComponent" parent="ShapeAppearance.Material3.Corner.Large">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">24dp</item>
    </style>

    <style name="Widget.Biashara.CardView" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">@dimen/biashara_corner_card</item>
        <item name="cardElevation">3dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">?attr/colorOutline</item>
        <item name="cardBackgroundColor">?attr/colorSurface</item>
    </style>

    <style name="Widget.Biashara.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="titleTextAppearance">@style/TextAppearance.Biashara.TitleLarge</item>
        <item name="subtitleTextAppearance">@style/TextAppearance.Biashara.BodyMedium</item>
        <item name="android:minHeight">56dp</item>
    </style>

    <style name="ThemeOverlay.Biashara.ActionBar" parent="">
        <item name="android:textColorPrimary">@color/biashara_charcoal</item>
        <item name="android:textColorSecondary">@color/biashara_muted</item>
    </style>

    <style name="ThemeOverlay.Biashara.ActionBar.Night" parent="">
        <item name="android:textColorPrimary">@color/biashara_night_text_primary</item>
        <item name="android:textColorSecondary">@color/biashara_night_text_secondary</item>
    </style>

    <style name="Widget.Biashara.BottomNavigationView" parent="Widget.Material3.BottomNavigationView">
        <item name="android:background">@color/biashara_nav_bar_bg</item>
        <item name="elevation">8dp</item>
        <item name="itemActiveIndicatorStyle">@style/Widget.Biashara.BottomNavigationView.ActiveIndicator</item>
        <item name="itemIconTint">@color/biashara_bottom_nav_icon</item>
        <item name="itemTextColor">@color/biashara_bottom_nav_text</item>
        <item name="itemRippleColor">@color/biashara_nav_ripple</item>
    </style>

    <style name="Widget.Biashara.BottomNavigationView.ActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/biashara_forest</item>
    </style>

    <style name="Widget.Biashara.ExtendedFloatingActionButton.Primary" parent="Widget.Material3.ExtendedFloatingActionButton.Primary">
        <item name="backgroundTint">@color/biashara_emerald</item>
        <item name="android:textColor">@color/biashara_surface_bright</item>
        <item name="iconTint">@color/biashara_surface_bright</item>
    </style>

    <style name="ThemeOverlay.Biashara.Toolbar.Dark" parent="">
        <item name="colorControlNormal">@color/biashara_surface_bright</item>
        <item name="actionMenuTextColor">@color/biashara_surface_bright</item>
        <item name="android:textColorPrimary">@color/biashara_surface_bright</item>
        <item name="android:textColorSecondary">@color/biashara_mint</item>
    </style>
</resources>
