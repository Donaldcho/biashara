<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingTop="4dp"
    android:paddingBottom="4dp">

    <!-- User message (right-aligned) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_user"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_marginStart="64dp"
        android:layout_marginEnd="4dp"
        android:visibility="gone"
        app:cardBackgroundColor="?attr/colorPrimary"
        app:cardCornerRadius="@dimen/biashara_corner_bubble"
        app:cardElevation="1dp"
        tools:visibility="visible">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp">

            <ImageView
                android:id="@+id/image_user_attachment"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:layout_gravity="end"
                android:adjustViewBounds="true"
                android:contentDescription="@string/chat_image_attachment_cd"
                android:scaleType="centerCrop"
                android:visibility="gone"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/text_user_message"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="4dp"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="?attr/colorOnPrimary"
                tools:text="How is my business doing this month?" />
        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- AI message (left-aligned) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_ai"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="start"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="64dp"
        android:visibility="gone"
        app:cardBackgroundColor="?attr/colorSurface"
        app:cardCornerRadius="@dimen/biashara_corner_bubble"
        app:cardElevation="1dp"
        app:strokeColor="?attr/colorOutline"
        app:strokeWidth="1dp"
        tools:visibility="gone">

        <TextView
            android:id="@+id/text_ai_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="?attr/colorOnSurface"
            tools:text="Your revenue this month is KES 45,000 with expenses of KES 23,500." />

    </com.google.android.material.card.MaterialCardView>

</FrameLayout>
