<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="8dp"
    android:paddingBottom="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="8dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/inference_dialog_intro"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="?android:attr/textColorSecondary" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:labelFor="@id/slider_max_tokens"
            android:text="@string/inference_max_tokens_label"
            android:textAppearance="?attr/textAppearanceLabelLarge" />

        <com.google.android.material.slider.Slider
            android:id="@+id/slider_max_tokens"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:stepSize="100"
            android:value="4000"
            android:valueFrom="2000"
            android:valueTo="4000"
            app:tickVisible="false" />

        <TextView
            android:id="@+id/text_max_tokens_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            tools:text="4000" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/inference_top_k_label"
            android:textAppearance="?attr/textAppearanceLabelLarge" />

        <com.google.android.material.slider.Slider
            android:id="@+id/slider_top_k"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:stepSize="1"
            android:value="64"
            android:valueFrom="5"
            android:valueTo="64"
            app:tickVisible="false" />

        <TextView
            android:id="@+id/text_top_k_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            tools:text="64" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/inference_top_p_label"
            android:textAppearance="?attr/textAppearanceLabelLarge" />

        <com.google.android.material.slider.Slider
            android:id="@+id/slider_top_p"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:stepSize="0.01"
            android:value="0.95"
            android:valueFrom="0"
            android:valueTo="0.95"
            app:tickVisible="false" />

        <TextView
            android:id="@+id/text_top_p_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            tools:text="0.95" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/inference_temperature_label"
            android:textAppearance="?attr/textAppearanceLabelLarge" />

        <com.google.android.material.slider.Slider
            android:id="@+id/slider_temperature"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:stepSize="0.01"
            android:value="1"
            android:valueFrom="0"
            android:valueTo="1"
            app:tickVisible="false" />

        <TextView
            android:id="@+id/text_temperature_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            tools:text="1.00" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/inference_accelerator_label"
            android:textAppearance="?attr/textAppearanceLabelLarge" />

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggle_accelerator"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            app:checkedButton="@id/btn_accel_gpu"
            app:selectionRequired="true"
            app:singleSelection="true">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_accel_gpu"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/inference_accel_gpu" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_accel_cpu"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/inference_accel_cpu" />

        </com.google.android.material.button.MaterialButtonToggleGroup>

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switch_enable_thinking"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/inference_enable_thinking" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/inference_enable_thinking_hint"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="?android:attr/textColorSecondary" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switch_enable_speculative"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/inference_enable_speculative" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/inference_enable_speculative_hint"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="?android:attr/textColorSecondary" />

    </LinearLayout>
</ScrollView>
