<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <FrameLayout
        android:id="@+id/frame_mic"
        android:layout_width="56dp"
        android:layout_height="56dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_mic"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@string/voice_ui_mic_idle"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            app:icon="@drawable/ic_mic"
            android:padding="0dp"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="26dp"
            tools:iconTint="@color/voice_teal" />

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/progress_mic"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone"
            android:indeterminate="true"
            app:indicatorSize="36dp"
            app:trackThickness="3dp"
            tools:visibility="visible" />
    </FrameLayout>

    <com.biasharaai.voice.TranscriptionBannerView
        android:id="@+id/banner_transcription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:visibility="gone"
        tools:visibility="visible" />
</merge>
