<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    android:orientation="vertical"
    tools:context=".ui.pos.PosFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_forest_hero_gradient"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="14dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/pos_title"
            android:textAppearance="?attr/textAppearanceTitleLarge"
            android:textColor="@color/biashara_surface_bright"
            android:textStyle="bold" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_customer"
            style="@style/Widget.Material3.Chip.Assist"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/pos_walk_in_customer"
            android:textColor="@color/biashara_forest_dark"
            app:chipBackgroundColor="@color/biashara_cream"
            app:chipStrokeWidth="0dp"
            app:closeIconVisible="false"
            app:ensureMinTouchTargetSize="true" />
    </LinearLayout>

    <HorizontalScrollView
        android:id="@+id/scroll_suggestions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="8dp"
        android:layout_marginTop="4dp"
        android:fillViewport="true"
        android:scrollbars="none"
        android:visibility="gone"
        tools:visibility="visible">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_suggestions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleLine="true" />
    </HorizontalScrollView>

    <TextView
        android:id="@+id/text_suggestion_subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="12dp"
        android:layout_marginTop="2dp"
        android:textAppearance="?attr/textAppearanceBodySmall"
        android:textColor="?android:attr/textColorSecondary"
        android:visibility="gone"
        tools:text="They often pick up milk on Fridays."
        tools:visibility="visible" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="8dp"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <androidx.appcompat.widget.SearchView
            android:id="@+id/search_view"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:iconifiedByDefault="false"
            android:queryHint="@string/pos_search_hint" />

            <ImageButton
                android:id="@+id/btn_voice_search"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/pos_voice_search_desc"
                android:padding="8dp"
                android:visibility="gone"
                app:srcCompat="@drawable/ic_mic"
                app:tint="?attr/colorControlNormal" />

            <ImageButton
                android:id="@+id/btn_scan"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/pos_scan_to_add_desc"
                android:padding="8dp"
                app:srcCompat="@drawable/ic_barcode_scan" />

            <ImageButton
                android:id="@+id/btn_transaction_history"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/pos_history_desc"
                android:padding="8dp"
                app:srcCompat="@drawable/ic_history"
                app:tint="?attr/colorControlNormal" />

            <ImageButton
                android:id="@+id/btn_pos_menu"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/pos_menu_overflow_desc"
                android:padding="8dp"
                app:srcCompat="@drawable/ic_more_vert"
                app:tint="?attr/colorControlNormal" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_search_results"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="8dp"
        android:maxHeight="220dp"
        android:visibility="gone"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        tools:itemCount="3"
        tools:listitem="@layout/item_product_search_result"
        tools:visibility="visible" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_product_grid"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="4dp"
        android:layout_marginTop="4dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="8dp"
        tools:listitem="@layout/item_product_grid" />

    <TextView
        android:id="@+id/text_cart_panel_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="12dp"
        android:paddingTop="8dp"
        android:text="@string/pos_cart_title"
        android:textAppearance="?attr/textAppearanceTitleSmall"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_cart_lines"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        tools:visibility="gone" />

    <com.biasharaai.ui.pos.TotalsBarView
        android:id="@+id/totals_bar"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="gone" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_pay_wide"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="12dp"
        android:layout_marginBottom="4dp"
        android:text="@string/pos_pay"
        android:visibility="gone" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cart_summary_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        app:cardBackgroundColor="@color/biashara_forest"
        app:cardCornerRadius="@dimen/biashara_corner_hero"
        app:cardElevation="4dp"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="12dp">

            <LinearLayout
                android:id="@+id/cart_summary_tap_area"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:orientation="vertical"
                android:paddingEnd="8dp">

                <TextView
                    android:id="@+id/text_cart_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_cart_badge_on_forest"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:textAppearance="?attr/textAppearanceLabelLarge"
                    android:textColor="@color/biashara_forest"
                    tools:text="3 items" />

                <TextView
                    android:id="@+id/text_cart_grand_total"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textAppearance="?attr/textAppearanceHeadlineSmall"
                    android:textColor="@color/biashara_surface_bright"
                    tools:text="KSh 500.00" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_pay_compact"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/pos_pay"
                android:textColor="@color/biashara_surface_bright"
                app:strokeColor="@color/biashara_surface_bright" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>
