<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="@dimen/screen_edge_padding"
    android:layout_marginEnd="@dimen/screen_edge_padding"
    android:layout_marginTop="4dp"
    android:layout_marginBottom="4dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardCornerRadius="12dp"
    app:cardElevation="1dp"
    app:contentPadding="16dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:id="@+id/image_thumb"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_product_thumb"
            android:contentDescription="@string/inventory_product_thumb_cd"
            android:scaleType="centerCrop"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/text_product_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textAlignment="viewStart"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            app:layout_constraintEnd_toStartOf="@id/icon_barcode"
            app:layout_constraintStart_toEndOf="@id/image_thumb"
            app:layout_constraintTop_toTopOf="@id/image_thumb"
            tools:text="Unga wa Ngano" />

        <ImageView
            android:id="@+id/icon_barcode"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:contentDescription="@string/inventory_barcode_icon_desc"
            android:src="@drawable/ic_barcode"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/text_product_name"
            app:layout_constraintBottom_toBottomOf="@id/text_product_name"
            app:tint="?attr/colorPrimary"
            tools:visibility="visible" />

        <TextView
            android:id="@+id/text_stock_quantity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="6dp"
            android:textAlignment="viewStart"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="?android:attr/textColorSecondary"
            app:layout_constraintStart_toEndOf="@id/image_thumb"
            app:layout_constraintTop_toBottomOf="@id/text_product_name"
            tools:text="Stock: 42" />

        <TextView
            android:id="@+id/text_price"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:textAlignment="viewStart"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="?attr/colorPrimary"
            app:layout_constraintBaseline_toBaselineOf="@id/text_stock_quantity"
            app:layout_constraintStart_toEndOf="@id/text_stock_quantity"
            tools:text="KES 150.00" />

        <TextView
            android:id="@+id/text_forecast"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_forecast_badge"
            android:drawablePadding="4dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:paddingStart="8dp"
            android:paddingTop="3dp"
            android:paddingEnd="8dp"
            android:paddingBottom="3dp"
            android:textAppearance="?attr/textAppearanceLabelSmall"
            android:textColor="?attr/colorOnPrimaryContainer"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/image_thumb"
            app:layout_constraintTop_toBottomOf="@id/text_stock_quantity"
            tools:text="📈 Day1: 6, Day2: 5, Day3: 7"
            tools:visibility="visible" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
